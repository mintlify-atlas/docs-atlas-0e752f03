  "keyFeatures": [
    "Cross-platform iOS sideloading (macOS, Linux, Windows)",
    "Sign and install apps with Apple ID authentication",
    "GUI and CLI interfaces for flexible workflows",
    "Tweak injection support with ElleKit",
    "P12 certificate generation for SideStore/AltStore",
    "Pairing file generation for remote device management",
    "Advanced entitlement handling and plugin registration",
